# Copy this file to `.env` (git-ignored) and fill in real values.
# NEVER commit real secrets. Dummy placeholders only live here.

# --- LLM provider ---
# The natural-language match uses OpenAI when this key is set (auto-loaded from .env).
# Model is configured in config/config.json -> llm.model (default gpt-4o-mini).
OPENAI_API_KEY=sk-your-openai-key-here
# Optional alternatives (not wired by default):
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Google OAuth (Gmail/Calendar agent) ---
# Absolute path to a SECRET folder OUTSIDE this repo holding
# client_secret.json and (after first consent) token.json.
MARL_GOOGLE_SECRETS_DIR=/absolute/path/outside/repo/secrets

# --- MCP servers (Phase 2/7) ---
# The two PUBLIC server URLs (one per agent). The client (check_mcp.py / play_remote.py)
# picks which one to talk to via its own --role flag — NOT via MCP_ROLE.
COP_MCP_URL=
THIEF_MCP_URL=
# Signing secret for HMAC bearer tokens (shared/mcp_auth.TokenAuth). Any long random string;
# use the SAME value on the server (Render) and here so minted tokens verify.
MCP_AUTH_SECRET=change-me-to-a-long-random-secret
# MCP_ROLE is SERVER-SIDE ONLY: it tells run_mcp_server.py which server a process becomes
# (cop|thief|host). A process is exactly one role, so this holds ONE value and is only the
# fallback used when you start a server locally without --role. In the cloud, Render sets it
# per service from render.yaml (cop-mcp=cop, thief-mcp=thief) and ignores this file. It does
# NOT choose which side you PLAY against a partner — that is the --role flag on play_remote.py.
MCP_ROLE=cop

# --- Inter-group live match (scripts/play_remote.py) ---
# The agreed shared HOST server (run by one team: run_mcp_server.py --role host) + its
# bearer token. If the PARTNER hosts, put THEIR url + the token THEY sent you here.
HOST_MCP_URL=
HOST_MCP_TOKEN=

# --- Prefect Cloud (Phase 7 deployment) ---
# Workspace URL + API key from app.prefect.cloud. Not used by the app until cloud
# deploy; the prefect CLI reads these (or run: uv run prefect cloud login -k <KEY>).
PREFECT_API_URL=
PREFECT_API_KEY=

# --- Optional overrides ---
# MARL_CONFIG_DIR=/absolute/path/to/config
